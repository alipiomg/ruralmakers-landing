$(function(){const e=document.getElementById("announcement-close"),t=e.parentNode;var n=t.id;const o=new Date,a=`goteo_announcements_${`${o.getFullYear()}-${o.getMonth()}-`+o.getDay()}_`+n;e.addEventListener("click",e=>{t.style.display="none",localStorage.setItem(a,!0)}),localStorage.getItem(a)||(t.style.display="block"),$(".slider-announcements").slick({dots:!1,infinite:!0,autoplay:!1,autoplaySpeed:7e3,speed:500,fade:!0,cssEase:"linear",responsive:[{breakpoint:500,settings:{dots:!0,arrows:!1}}]})});