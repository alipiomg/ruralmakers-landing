# Rural Makers - Variables de entorno
# Copia este archivo como .env y rellena los valores
# NUNCA uses prefijo VITE_ para secretos (se exponen al navegador)

# Goteo API (backend proxy)
GOTEO_USER=
GOTEO_KEY=

# Admin auth (server-side only)
# Genera el hash con: node scripts/hash-pin.js TuPinSecreto
ADMIN_PIN_HASH=
# Genera un secret aleatorio con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_JWT_SECRET=

# AI APIs (desactivadas hasta implementar proxy backend)
# GEMINI_API_KEY=
# HIGGSFIELD_API_KEY_ID=
# HIGGSFIELD_API_SECRET=
